// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Gift {
  id             String      @id @default(cuid())
  name           String
  description    String
  imageUrl       String
  priceInCents   Int
  quantity       Int
  giftedQuantity Int         @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orders         GiftOrder[]
}

model GiftOrder {
  id               String   @id @default(cuid())
  giftId           String
  quantity         Int
  unitPriceInCents Int
  totalInCents     Int
  guestName        String?
  guestEmail       String?
  guestMessage     String?
  status           String   @default("PENDING")
  paymentProvider  String?
  paymentReference String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  gift             Gift     @relation(fields: [giftId], references: [id], onDelete: Restrict)

  @@index([giftId])
  @@index([status])
}

model WeddingSettings {
  id                 String   @id @default("wedding")
  invitePriceInCents Int      @default(0)
  totalInvites       Int      @default(0)
  reservationMinutes Int     @default(15)
  inviteSalesEnabled Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model InviteReservation {
  id               String        @id @default(cuid())
  buyerName        String
  buyerEmail       String
  buyerPhone       String?
  quantity         Int
  unitPriceInCents Int
  totalInCents     Int
  status           String        @default("PENDING")
  expiresAt        DateTime
  paymentProvider  String?
  paymentReference String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  guests            InviteGuest[]

  @@index([status])
  @@index([expiresAt])
}

model InviteGuest {
  id            String            @id @default(cuid())
  reservationId String
  name          String
  isBuyer       Boolean           @default(false)
  checkedInAt   DateTime?
  createdAt     DateTime          @default(now())
  reservation   InviteReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([name])
}
